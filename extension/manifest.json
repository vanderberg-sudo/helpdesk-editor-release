{
  "manifest_version": 3,
  "name": "CA-Capture",
  "version": "1.2.1",
  "description": "Capture web app workflows and generate how-to articles with AI.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabCapture",
    "tabs",
    "offscreen",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "CA-Capture",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "128": "icons/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "src/recording-panel.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "editor/editor.html",
        "editor/recent.html",
        "editor/manage.html",
        "src/recording-panel.html",
        "src/recording-panel.css",
        "src/recording-panel.js",
        "icons/*",
        "editor/wp-import.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}